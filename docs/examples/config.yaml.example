# .sam/config.yaml
# SAM Framework — repository configuration
# COMMITTED TO REPO — applies to everyone working in this monorepo
# Docs: https://github.com/sam-framework/sam/docs/config.md

version: "1.0"

# ─────────────────────────────────────────────
# MonoGraph dependency analysis engine
# ─────────────────────────────────────────────
monograph:
  port: 7474
  host: "127.0.0.1"           # always localhost — never expose externally

  # Co-change analysis tuning
  min_cochange_score: 0.3     # ignore co-changes below this score (0.0–1.0)
  max_git_log_commits: 500    # how far back to mine git history

  # Parser configuration
  parsers:
    - typescript
    - javascript
    - python
    - java
    - go
    - csharp

  # Path alias mappings (maps import aliases to domain folders)
  # Match to your tsconfig.json paths or build tool aliases
  path_aliases:
    "@company/shared-auth": "shared/auth"
    "@company/shared-types": "shared/types"
    "@company/shared-media": "shared/media"
    "~shared": "shared"

  # Directories to exclude from analysis
  exclude:
    - "node_modules"
    - ".git"
    - "dist"
    - "build"
    - "__pycache__"
    - ".sam"
    - "*.test.ts"
    - "*.spec.ts"

# ─────────────────────────────────────────────
# MonoWatch pre-push hook
# ─────────────────────────────────────────────
monowatch:
  # Set to true to BLOCK pushes when critical-risk domains are affected
  # Default false — advisory mode only
  block_on_critical: false

  # Domains that always count as critical (regardless of call volume)
  always_critical:
    - "shared/auth"
    - "shared/types"
    - "apis/payments"

  # Show co-change risk entries in impact report
  show_cochange: true

  # Minimum co-change score to show in impact report
  min_cochange_display: 0.4

# ─────────────────────────────────────────────
# Deploy configuration
# ─────────────────────────────────────────────
deploy:
  # {domain} is replaced with the actual domain path
  # Override per-profile in profiles.yaml
  default_command: "kubectl apply -f k8s/{domain}/"

  # CI system to notify (future feature — set to none for now)
  ci_trigger: "none"  # options: none, github_actions, gitlab_ci

# ─────────────────────────────────────────────
# Domain structure hints
# ─────────────────────────────────────────────
repo:
  # Top-level folders that contain domain subfolders
  domain_roots:
    - "apis"
    - "services"
    - "shared"
    - "workers"

  # Folders that are always included (never ghost)
  always_include:
    - ".sam"
    - "docs"
    - "scripts"
